# GitHubGreenCard — Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NOTE: .env is gitignored — secrets never committed.

# ── Required ──────────────────────────────────────────────────────

# NVIDIA NIM API key (free tier: 1,000 credits, 40 req/min)
# Sign up at https://build.nvidia.com to get a key (starts with "nvapi-")
NVIDIA_API_KEY="nvapi-..."

# ── Optional ──────────────────────────────────────────────────────

# Fallback: OpenAI API key (used only if NVIDIA_API_KEY is not set)
# OPENAI_API_KEY="sk-..."

# Dry-run mode: set to "true" to skip git operations
# Useful for testing ingestion + LLM flow locally
# DRY_RUN="true"

# ── CI Only (set automatically by GitHub Actions) ────────────────

# GitHub Actions auto-injects this for push authentication
# GITHUB_TOKEN="..."
